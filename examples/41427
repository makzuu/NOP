# sequences are zero-terminated
# read a sequence from in
# write the min value to out
# write the max value to out

jmp start

max:
push bp
mov sp, bp

define max, 0
define index, 1

push nil
push nil

#  v bp
# [2, 4, 1, 0, nexti, bp, -5, 4]
#              ^ sp
# acc = 3

mov -6, bp(index)
mov -999, bp(max)

getmax:
mov *bp(index), acc
jez endgetmax

mov bp(max), acc
sub *bp(index)
jlz newmax
jro 2

newmax:
mov *bp(index), bp(max)

mov bp(index), acc
add 1
mov acc, bp(index)
jmp getmax

endgetmax:
mov bp(max), acc

mov bp, sp
pop bp

ret

start:
# read values till 0 is found
loop:
read
mov sp(-1), acc		# the stack pointer points to the position the next value will be pushed
jnz loop

call max
write acc
